# Source build outputs
open-source/**/bin/
open-source/**/obj/
open-source/.vs/

# Portable runtime data generated after launch
portable-exe/maFiles/*
!portable-exe/maFiles/README.txt

# Steam Guard and account secrets (never commit)
**/*.maFile
**/maFiles/**
!portable-exe/maFiles/README.txt
**/manifest.json
**/credentials.json
**/credentials.secure.json
**/cloud.secret.json
**/webdav.secret.json
**/*cookie*.json
**/*token*.json
**/*secret*.local.json
**/backups/**

# Common local artifacts
*.zip
*.7z
*.tmp
*.log
